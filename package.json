{
  "name": "tv-slides",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"blue,green\" \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "db:migrate": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && prisma migrate dev",
    "db:seed": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && prisma db seed",
    "db:generate": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && prisma generate",
    "db:push": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && prisma db push",
    "db:reset": "set NODE_TLS_REJECT_UNAUTHORIZED=0 && prisma migrate reset --force"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
